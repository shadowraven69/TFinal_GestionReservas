# ─────────────────────────────────────────────────
# Configuración del Sistema de Reservas
# Copiar este archivo como .env y ajustar valores
# ─────────────────────────────────────────────────

# ─── Base de Datos ───────────────────────────────
# Para desarrollo local (sin Docker):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/reservas_db
# Para Docker Compose (el host es el nombre del servicio):
DATABASE_URL=postgresql://postgres:postgres@db:5432/reservas_db

# ─── JWT ─────────────────────────────────────────
# Clave secreta para firmar los tokens JWT
# En producción, generar con: openssl rand -hex 32
SECRET_KEY=change-me-in-production
ALGORITHM=HS256
# Tiempo de expiración del token en minutos
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── CORS ────────────────────────────────────────
# Orígenes permitidos para CORS (formato JSON array)
BACKEND_CORS_ORIGINS=["http://localhost:3000"]

# ─── Frontend ────────────────────────────────────
# URL del backend para el frontend
# Desarrollo local: http://localhost:8000
# Docker: http://localhost:8000
NEXT_PUBLIC_API_URL=http://localhost:8000
